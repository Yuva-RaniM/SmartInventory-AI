htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.py,cover
.hypothesis/
.pytest_cache/
cover/

# Translations
*.mo
*.pot

# Django stuff:
*.log
local_settings.py
db.sqlite3
db.sqlite3-journal

# Flask stuff:
instance/
.webassets-cache

# Scrapy stuff:
.scrapy

# Sphinx documentation
docs/_build/

# PyBuilder
.pybuilder/
target/

# Jupyter Notebook
.ipynb_checkpoints

# IPython
profile_default/
ipython_config.py

# pyenv
#   For a library or app, you might want to share your .python-version.
#   Web projects and the like:
#.python-version

# pipenv
#   According to pypa/pipenv#598, it is recommended to include Pipfile.lock in version control.
#   However, in case of collaboration, if delegates have different operating systems or architectures,
#   this may cause system-specific issues.
#Pipfile.lock

# poetry
#   Similar to Pipfile.lock, poetry.lock contains the exact dependency versions.
#   It is recommended to commit poetry.lock.
#poetry.lock

# pdm
#   Similar to Pipfile.lock, pdm.lock contains the exact dependency versions.
#pdm.lock

# virtualenv
.venv/
venv/
ENV/
env/
./env/
./venv/

# IDEs and editors
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Project specific exclusions
.env
data/raw/*.csv
data/cleaned/*.csv
data/processed/*.csv
!data/raw/SmartInventory_AI_Raw_Dataset.csv
!data/cleaned/SmartInventory_AI_Cleaned_Dataset.csv
!data/processed/SmartInventory_AI_Feature_Engineered.csv
*.db
*.sqlite
*.pkl
models/*.pkl
reports/figures/*.png
reports/figures/*.html
dashboards/excel/*.xlsx
!dashboards/excel/SmartInventory_AI_Executive_Dashboard.xlsx
